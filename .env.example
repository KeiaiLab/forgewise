# GitLab 인스턴스 URL (필수)
GITLAB_BASE_URL=https://gitlab.example.com

# GitLab Personal Access Token (필수, read_api scope)
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitLab API 타임아웃 (초, 기본: 10)
GITLAB_TIMEOUT=10

# 변경성 도구 활성화 (create_issue, create_merge_request 등)
# 미설정 시 변경성 도구는 차단됨 (fail-closed)
FORGEWISE_ENABLE_MUTATIONS=1

# OAuth 2.0 인증 강제 (HTTP MCP 서버)
FORGEWISE_REQUIRE_OAUTH=0

# 분석 대상 저장소 루트 경로
FORGEWISE_REPO_ROOT=/path/to/your/repo

# --- LLM 백엔드 설정 (선택) ---
# 백엔드 선택: "ollama" | "openai" | "none" (기본: none = AI 기능 비활성)
FORGEWISE_LLM_BACKEND=none

# LLM API base URL (Ollama 기본: http://localhost:11434, OpenAI 기본: https://api.openai.com)
# FORGEWISE_LLM_BASE_URL=http://localhost:11434

# 모델명 (Ollama 기본: llama3.2, OpenAI 기본: gpt-4o-mini)
# FORGEWISE_LLM_MODEL=llama3.2

# OpenAI 호환 API 키 (OpenAI 백엔드 사용 시 필수)
# FORGEWISE_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# LLM 요청 타임아웃 (초, 기본: 60)
# FORGEWISE_LLM_TIMEOUT=60

# 최대 생성 토큰 수 (기본: 2048)
# FORGEWISE_LLM_MAX_TOKENS=2048
